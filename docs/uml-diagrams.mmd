%% ============================================================================
%% BSI Test Dashboard — UML Diagrams
%% Cloudflare Pages + KV-backed test results dashboard with Firebase Auth
%% ============================================================================

%% === CLASS DIAGRAM ===
classDiagram
    class DashboardApp {
        -Object runsIndex
        -Map runCache
        -Array events
        -Object manifests
        -String runsSortKey
        -Boolean runsSortAsc
        -String runsFilterMode
        -Set selectedRuns
        -Map charts
        +initDashboard()
        +loadAll() Promise
        +showSection(id, el)
        +toggleTheme()
    }

    class AuthModule {
        -Object FIREBASE_CONFIG
        -Object fbApp
        -Object auth
        -Object googleProvider
        +signInWithGoogle()
        +signOut()
        -onAuthStateChanged(user)
    }

    class RunsIndex {
        +String lastUpdated
        +Array~RunSummary~ runs
    }

    class RunSummary {
        +String id
        +String timestamp
        +String version
        +String mode
        +Number totalPass
        +Number totalFail
        +Number totalSkip
        +Number totalTests
        +Number passRate
        +Number elapsed
    }

    class TestRun {
        +String id
        +String timestamp
        +String mode
        +String runner
        +String hostname
        +Boolean completed
        +Number totalPass
        +Number totalFail
        +Number totalSkip
        +Number totalTests
        +Number elapsed
        +Number passRate
        +Array~SuiteResult~ suites
        +Object manifest
        +String manifestVersion
        +String manifestDate
    }

    class SuiteResult {
        +String name
        +Number totalTests
        +Number pass
        +Number fail
        +Number skip
        +Array~TestDetail~ tests
    }

    class TestDetail {
        +String name
        +String status
        +String error
        +Number elapsed
    }

    class ManifestIndex {
        +Array~ManifestVersion~ versions
    }

    class ManifestVersion {
        +String version
        +String date
        +Number repoCount
    }

    class ReleaseManifest {
        +String version
        +String date
        +String description
        +Map~String,RepoEntry~ repos
    }

    class RepoEntry {
        +String commit
        +String repo
    }

    class WebhookEvent {
        +String timestamp
        +String type
        +String repo
        +String ref
        +String commitHash
        +String commitMessage
        +String author
        +Boolean manifestChanged
        +String version
        +String fetchError
    }

    class ApiRuns {
        +onRequestGet(env) Response
        +onRequestPost(request, env) Response
        +onRequestOptions() Response
    }

    class ApiRunDetail {
        +onRequestGet(params, env) Response
        +onRequestDelete(params, env) Response
        +onRequestOptions() Response
    }

    class ApiEvents {
        +onRequestGet(env) Response
        +onRequestOptions() Response
    }

    class ApiManifests {
        +onRequestGet(request, env) Response
        +onRequestOptions() Response
    }

    class ApiWebhook {
        +onRequestPost(request, env) Response
        +onRequestOptions() Response
        -verifySignature(request, secret) Boolean
    }

    class SubmitRunScript {
        +String DASHBOARD_URL
        +String MANIFEST_FILE
        +String INPUT_FILE
        +parseArguments()
        +readInput() String
        +validateJson(json) Boolean
        +mergeManifest(run, manifest)
        +submitToDashboard(json)
    }

    class CloudflareKV {
        +get(key, type) Promise
        +put(key, value) Promise
        +delete(key) Promise
    }

    class SuiteCoverageMap {
        +Map~String,Array~ SUITE_COVERAGE
        +Array ALL_TEST_APPS
        +Array MANIFEST_REPOS
    }

    class OverviewSection {
        +renderStats(runsIndex)
        +renderLatestRun(run)
        +renderPassRateChart(runs)
        +renderSuiteHealthChart(run)
        +renderRecentEvents(events)
    }

    class RunsSection {
        +renderRunsTable()
        +filterRunsMode(el, mode)
        +sortRuns(key)
        +compareSelected()
    }

    class DetailSection {
        +showRunDetail(id) Promise
        +renderRunDetail(run)
        +renderSuiteBreakdown(suites)
    }

    class ManifestSection {
        +renderManifestExplorer(manifests)
        +loadManifestVersion(version)
    }

    class CoverageSection {
        +renderCoverageMatrix()
        +renderUntestedRepos()
    }

    class TrendsSection {
        +renderPassRateTrend()
        +renderDurationTrend()
        +renderFailureHeatmap()
        +renderSuiteStability()
        +detectFlakyTests()
    }

    class RemoteRunner {
        +IframeOrchestrator orch
        +TestHarness harness
        +PostMessageSpy spy
        +runTests(suite)
        +buildPayload() Object
        +postToDashboard()
        +exportForDashboard()
        -fetchManifest() Promise~Object~
    }

    class IframeOrchestrator {
        +String target
        +String baseUrl
        +Boolean demoMode
        +Array handles
        +loadApp(appId) Promise~AppHandle~
        +unloadApp(handle)
        +unloadAll()
        +sendMessage(handle, msg)
        +waitForMessage(handle, type, timeout) Promise
        +evalInApp(handle, expr)
    }

    DashboardApp --> AuthModule : authenticates via
    DashboardApp --> RunsIndex : fetches
    DashboardApp --> OverviewSection : renders
    DashboardApp --> RunsSection : renders
    DashboardApp --> DetailSection : renders
    DashboardApp --> ManifestSection : renders
    DashboardApp --> CoverageSection : renders
    DashboardApp --> TrendsSection : renders
    DashboardApp --> SuiteCoverageMap : uses

    RunsIndex --> RunSummary : contains
    TestRun --> SuiteResult : contains
    SuiteResult --> TestDetail : contains
    TestRun --> ReleaseManifest : embeds
    ManifestIndex --> ManifestVersion : contains
    ReleaseManifest --> RepoEntry : contains

    ApiRuns --> CloudflareKV : reads/writes runs:index, runs:{id}
    ApiRuns --> CloudflareKV : writes manifests:{version}
    ApiRunDetail --> CloudflareKV : reads/deletes runs:{id}
    ApiEvents --> CloudflareKV : reads events:log
    ApiManifests --> CloudflareKV : reads manifests:index, manifests:{version}
    ApiWebhook --> CloudflareKV : writes events:log, manifests:{version}

    RemoteRunner --> IframeOrchestrator : uses
    RemoteRunner ..> ApiRuns : POST results
    RemoteRunner ..> ApiManifests : GET manifest

    SubmitRunScript ..> ApiRuns : POST via curl

    DetailSection --> TestRun : displays


%% === SEQUENCE DIAGRAM: Submit Test Run (POST /api/runs) ===
sequenceDiagram
    participant Runner as Remote Runner (runner.html)
    participant API as Cloudflare Function /api/runs
    participant KV as Cloudflare KV (BSI_DASHBOARD)

    Runner ->> Runner: Tests complete, buildPayload()
    Note over Runner: Collect _testResults<br/>Fetch manifest (dashboard API or GitHub)<br/>Build payload with suites, manifest, metadata

    Runner ->> API: POST /api/runs
    Note over Runner: {timestamp, totalPass, totalFail, totalTests,<br/>suites, manifest, manifestVersion, ...}
    activate API

    API ->> API: Parse request JSON
    alt Invalid JSON
        API -->> Runner: 400 {error: "Invalid JSON"}
    end

    API ->> API: Validate required fields
    Note over API: Check: timestamp, totalPass, totalFail, totalTests, suites
    alt Missing required field
        API -->> Runner: 400 {error: "Missing required field: X"}
    end

    opt No run.id provided
        API ->> API: Generate ID
        Note over API: id = "{timestamp}_v{version}_{mode}"
    end

    opt passRate not provided
        API ->> API: Compute passRate
        Note over API: passRate = round(totalPass / totalTests * 1000) / 10
    end

    API ->> API: Enrich suite data
    loop For each suite
        Note over API: Auto-compute pass, fail, skip, totalTests from tests array
    end

    API ->> KV: put("runs:{id}", JSON.stringify(run))
    KV -->> API: Stored

    API ->> KV: get("runs:index", "json")
    KV -->> API: Existing index (or null)

    API ->> API: Build summary entry
    Note over API: {id, timestamp, version, mode, totalPass, totalFail,<br/>totalSkip, totalTests, passRate, elapsed}

    API ->> API: Prepend to index, deduplicate
    API ->> KV: put("runs:index", JSON.stringify(updatedIndex))
    KV -->> API: Stored

    opt run.manifest && run.manifestVersion provided
        API ->> KV: get("manifests:{version}")
        KV -->> API: existing manifest (or null)

        alt Manifest version is new
            API ->> KV: put("manifests:{version}", JSON.stringify(manifest))
            KV -->> API: Stored

            API ->> KV: get("manifests:index", "json")
            KV -->> API: Manifest index

            opt Version not in index
                API ->> API: Prepend version to index
                API ->> KV: put("manifests:index", JSON.stringify(updatedMIndex))
                KV -->> API: Stored
            end
        end
    end

    API -->> Runner: 201 {ok: true, id: "2026-03-23T..."}
    deactivate API

    Runner ->> Runner: Display "Submitted! ID: ..."


%% === SEQUENCE DIAGRAM: GitHub Webhook Processing ===
sequenceDiagram
    participant GitHub
    participant Webhook as Cloudflare Function /api/webhook
    participant KV as Cloudflare KV (BSI_DASHBOARD)
    participant GitHubAPI as GitHub Content API

    GitHub ->> Webhook: POST /api/webhook
    Note over GitHub: X-GitHub-Event: push<br/>X-Hub-Signature-256: sha256=...<br/>Body: {ref, commits, repository, head_commit}
    activate Webhook

    alt WEBHOOK_SECRET configured
        Webhook ->> Webhook: verifySignature(request, secret)
        Note over Webhook: HMAC-SHA256 verification
        alt Invalid signature
            Webhook -->> GitHub: 401 {error: "Invalid signature"}
        end
    end

    Webhook ->> Webhook: Parse event type from headers
    alt Not a push event
        Webhook -->> GitHub: 200 {ok: true, skipped: "Not a push event"}
    end

    Webhook ->> Webhook: Check ref ends with /main or /master
    alt Not default branch
        Webhook -->> GitHub: 200 {ok: true, skipped: "Not default branch"}
    end

    Webhook ->> Webhook: Check if release-manifest.json modified
    loop For each commit
        Note over Webhook: Check commit.modified and commit.added arrays
    end

    Webhook ->> Webhook: Build logEntry
    Note over Webhook: {timestamp, type, repo, ref, commitHash,<br/>commitMessage, author, manifestChanged}

    alt manifestChanged == true
        Webhook ->> GitHubAPI: GET repos/{owner}/{repo}/contents/release-manifest.json
        activate GitHubAPI
        alt Fetch successful
            GitHubAPI -->> Webhook: Manifest JSON
            deactivate GitHubAPI

            Note over Webhook: Extract version from manifest
            Webhook ->> KV: get("manifests:{version}")
            KV -->> Webhook: null (new version)

            alt New version
                Webhook ->> KV: put("manifests:{version}", JSON.stringify(manifest))
                KV -->> Webhook: Stored

                Webhook ->> KV: get("manifests:index", "json")
                KV -->> Webhook: Index

                opt Version not in index
                    Webhook ->> Webhook: Prepend to index
                    Webhook ->> KV: put("manifests:index", JSON.stringify(index))
                    KV -->> Webhook: Stored
                end
            end
        else Fetch failed
            GitHubAPI -->> Webhook: Error
            Note over Webhook: logEntry.fetchError = error message
        end
    end

    Webhook ->> KV: get("events:log", "json")
    KV -->> Webhook: Existing event log (or [])

    Webhook ->> Webhook: Prepend logEntry, cap at 100 entries
    Webhook ->> KV: put("events:log", JSON.stringify(eventLog))
    KV -->> Webhook: Stored

    Webhook -->> GitHub: 200 {ok: true, event: logEntry}
    deactivate Webhook


%% === SEQUENCE DIAGRAM: Dashboard Initialization and Data Loading ===
sequenceDiagram
    participant Browser
    participant LoginScreen as Login Screen
    participant Firebase as Firebase Auth
    participant Google as Google OAuth
    participant Dashboard as Dashboard App
    participant API_Runs as /api/runs
    participant API_Events as /api/events
    participant API_Manifests as /api/manifests
    participant ChartJS as Chart.js

    Browser ->> LoginScreen: Load index.html
    LoginScreen ->> Firebase: firebase.initializeApp(config)
    Firebase -->> LoginScreen: Auth instance ready

    LoginScreen ->> Firebase: auth.onAuthStateChanged(callback)

    alt User not authenticated
        Note over LoginScreen: Show login screen
        Browser ->> LoginScreen: Click "Sign in with Google"
        LoginScreen ->> Firebase: auth.signInWithPopup(googleProvider)
        Firebase ->> Google: OAuth popup
        Google -->> Firebase: OAuth token
        Firebase -->> LoginScreen: User object
    else User already authenticated
        Firebase -->> LoginScreen: Cached user session
    end

    LoginScreen ->> LoginScreen: Hide login, show dashboard
    LoginScreen ->> LoginScreen: Render user info in sidebar
    LoginScreen ->> Dashboard: initDashboard()
    activate Dashboard

    Dashboard ->> Dashboard: loadAll()
    activate Dashboard

    par Parallel API calls
        Dashboard ->> API_Runs: GET /api/runs
        API_Runs -->> Dashboard: {lastUpdated, runs: [...]}

        Dashboard ->> API_Events: GET /api/events
        API_Events -->> Dashboard: [{timestamp, type, repo, ...}, ...]

        Dashboard ->> API_Manifests: GET /api/manifests
        API_Manifests -->> Dashboard: {versions: [{version, date, repoCount}, ...]}
    end

    deactivate Dashboard

    Dashboard ->> Dashboard: renderOverview()
    Note over Dashboard: Update stat cards (pass rate, total runs, version)

    alt Runs exist
        Dashboard ->> Dashboard: renderLatestRunSummary()
        Note over Dashboard: Show latest run pass/fail bar

        Dashboard ->> ChartJS: new Chart(passRateCanvas, config)
        ChartJS -->> Dashboard: Pass rate trend chart

        Dashboard ->> ChartJS: new Chart(suiteHealthCanvas, config)
        ChartJS -->> Dashboard: Suite health bar chart
    end

    Dashboard ->> Dashboard: renderRecentEvents(events)
    Note over Dashboard: Show last 10 webhook events

    Dashboard ->> Dashboard: renderCoverageMatrix()
    Note over Dashboard: Build apps x suites grid from SUITE_COVERAGE map

    Dashboard ->> Dashboard: Handle URL hash routing
    opt Hash is #run/{id}
        Dashboard ->> API_Runs: GET /api/run/{id}
        API_Runs -->> Dashboard: Full test run data
        Dashboard ->> Dashboard: showRunDetail(run)
    end

    deactivate Dashboard


%% === SEQUENCE DIAGRAM: Remote Test Runner Execution ===
sequenceDiagram
    participant Browser
    participant RunnerPage as runner.html
    participant Harness as Test Harness (inline)
    participant Orch as IframeOrchestrator (inline)
    participant Spy as PostMessageSpy (inline)
    participant CF as Cloudflare Pages App
    participant DashAPI as Dashboard /api/runs
    participant GitHubAPI as GitHub API
    participant ManifestAPI as Dashboard /api/manifests

    Browser ->> RunnerPage: Load runner.html?suite=smoke
    activate RunnerPage

    RunnerPage ->> RunnerPage: Inline test harness
    RunnerPage ->> RunnerPage: Inline IframeOrchestrator (remote mode)
    RunnerPage ->> RunnerPage: Inline PostMessageSpy
    RunnerPage ->> RunnerPage: Set _testMode = "demo", _testTarget = "remote"

    Note over RunnerPage: Register inline test suites
    RunnerPage ->> Harness: describe("Smoke - All Apps Load (Remote)", fn)
    loop For each app in URL_MAP (excluding aliases)
        RunnerPage ->> Harness: it(appId + " loads", async fn, {timeout: 20000})
    end
    RunnerPage ->> Harness: describe("SSO - Admin Auth Chain (Remote)", fn)
    RunnerPage ->> Harness: describe("Theme Propagation - Remote", fn)
    RunnerPage ->> Harness: describe("Regression - Remote", fn)

    RunnerPage ->> Harness: runAll({suite: suiteFilter})
    activate Harness

    loop For each suite
        loop For each test
            Harness ->> Orch: new IframeOrchestrator({target: "remote", demoMode: true})
            Harness ->> Orch: loadApp(appId)
            activate Orch
            Orch ->> Orch: Resolve URL from URL_MAP
            Note over Orch: e.g. "scrum-app" -> "https://scrum-app.pages.dev/?demo=true"
            Orch ->> CF: Create iframe with src = production URL
            activate CF
            CF -->> Orch: Page loaded (cross-origin)
            deactivate CF
            Note over Orch: Wait 500ms for init
            Orch -->> Harness: AppHandle
            deactivate Orch

            opt SSO test
                Harness ->> Orch: sendMessage(handle, {type: "admin-auth", ...})
                Orch ->> CF: iframe.contentWindow.postMessage(...)
                Note over Harness: wait(1000)
            end

            opt Theme test
                Harness ->> Orch: sendMessage(handle, {type: "theme-change", theme: "light"})
                Orch ->> CF: iframe.contentWindow.postMessage(...)
                Note over Harness: wait(500)
            end

            Harness ->> Harness: assertAppLoaded(handle)
            Note over Harness: Check handle exists, iframe in DOM

            Harness ->> Orch: unloadApp(handle)
        end
    end

    Harness -->> RunnerPage: _testResults
    deactivate Harness

    RunnerPage ->> RunnerPage: Render summary (pass/fail counts)
    RunnerPage ->> RunnerPage: Show export bar

    opt User clicks "POST to Dashboard"
        RunnerPage ->> RunnerPage: buildPayload()
        activate RunnerPage

        RunnerPage ->> RunnerPage: fetchManifest()

        alt Try dashboard API first
            RunnerPage ->> ManifestAPI: GET /api/manifests
            ManifestAPI -->> RunnerPage: {versions: [...]}
            RunnerPage ->> ManifestAPI: GET /api/manifests?version=latest
            ManifestAPI -->> RunnerPage: Manifest JSON
        else Fall back to GitHub API
            RunnerPage ->> GitHubAPI: GET repos/arnoutzw/bsi-devops/contents/release-manifest.json
            GitHubAPI -->> RunnerPage: Manifest JSON
        end

        RunnerPage ->> RunnerPage: Compose full payload
        Note over RunnerPage: {timestamp, mode, runner, totalPass,<br/>totalFail, suites, manifest, manifestVersion, ...}

        deactivate RunnerPage

        RunnerPage ->> DashAPI: POST /api/runs (payload)
        DashAPI -->> RunnerPage: 201 {ok: true, id: "..."}
        RunnerPage ->> RunnerPage: Display "Submitted! ID: ..."
    end

    deactivate RunnerPage


