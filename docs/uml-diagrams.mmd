%% === STATE DIAGRAM ===
stateDiagram-v2
    state "Dashboard App States" as DashboardStates {
        [*] --> Unauthenticated : Page loaded

        state Unauthenticated {
            [*] --> ShowLoginScreen
            ShowLoginScreen --> AuthPending : Click Sign In
            AuthPending --> ShowLoginScreen : Auth cancelled / error
        }

        Unauthenticated --> Authenticated : Firebase auth success

        state Authenticated {
            [*] --> LoadingData
            LoadingData --> DataReady : API calls complete

            state DataReady {
                [*] --> OverviewView
                OverviewView --> RunsView : Click Runs nav
                RunsView --> DetailView : Click run row
                DetailView --> RunsView : Click Back
                OverviewView --> ManifestView : Click Manifest nav
                OverviewView --> CoverageView : Click Coverage nav
                OverviewView --> TrendsView : Click Trends nav
                OverviewView --> SettingsView : Click Settings nav
                RunsView --> OverviewView : Click Overview nav
                ManifestView --> OverviewView : Click Overview nav
                CoverageView --> OverviewView : Click Overview nav
                TrendsView --> OverviewView : Click Overview nav
                SettingsView --> OverviewView : Click Overview nav
            end
        end

        Authenticated --> Unauthenticated : Sign out
    }

    state "Test Run Lifecycle" as TestRunLifecycle {
        [*] --> RunCreated : Runner generates results

        state RunCreated {
            [*] --> LocalResults
            LocalResults --> PayloadBuilt : buildPayload()

            state PayloadBuilt {
                [*] --> FetchingManifest
                FetchingManifest --> ManifestFromDashboard : Dashboard API has manifest
                FetchingManifest --> ManifestFromGitHub : Fallback to GitHub API
                FetchingManifest --> NoManifest : Both sources fail
                ManifestFromDashboard --> PayloadReady
                ManifestFromGitHub --> PayloadReady
                NoManifest --> PayloadReady : manifest = null
            }
        end

        PayloadReady --> Submitting : POST to /api/runs
        Submitting --> StoredInKV : 201 response
        Submitting --> SubmitFailed : Error response

        StoredInKV --> IndexUpdated : Index prepended
        IndexUpdated --> ManifestSnapshotted : New manifest version stored

        state ManifestSnapshotted {
            [*] --> CheckExisting
            CheckExisting --> AlreadyExists : Version known
            CheckExisting --> StoreNewManifest : New version
            StoreNewManifest --> UpdateManifestIndex
        }

        ManifestSnapshotted --> RunComplete : All stored

        RunComplete --> [*]
        SubmitFailed --> [*]
    }

    state "Webhook Event Processing" as WebhookStates {
        [*] --> EventReceived : GitHub sends POST

        EventReceived --> VerifyingSignature

        state VerifyingSignature {
            [*] --> CheckSecret
            CheckSecret --> ValidateHMAC : WEBHOOK_SECRET set
            CheckSecret --> SkipVerification : No secret configured
            ValidateHMAC --> SignatureValid : HMAC matches
            ValidateHMAC --> SignatureInvalid : HMAC mismatch
        }

        SkipVerification --> CheckEventType
        SignatureValid --> CheckEventType
        SignatureInvalid --> Rejected : 401

        state CheckEventType {
            [*] --> IsPushEvent
            IsPushEvent --> CheckBranch : event == push
            IsPushEvent --> Skipped : not push event
        }

        state CheckBranch {
            [*] --> IsDefaultBranch
            IsDefaultBranch --> CheckManifest : ref ends with /main or /master
            IsDefaultBranch --> Skipped : not default branch
        }

        state CheckManifest {
            [*] --> ScanCommits
            ScanCommits --> ManifestChanged : release-manifest.json in modified/added
            ScanCommits --> PushOnly : manifest not changed
        }

        ManifestChanged --> FetchNewManifest
        FetchNewManifest --> StoreManifest : Fetch OK
        FetchNewManifest --> LogFetchError : Fetch failed

        StoreManifest --> AppendToEventLog
        LogFetchError --> AppendToEventLog
        PushOnly --> AppendToEventLog

        AppendToEventLog --> TrimLog : Keep last 100 entries
        TrimLog --> EventStored
        EventStored --> [*]
        Rejected --> [*]
        Skipped --> [*]
    }

    state "Theme States" as ThemeStates {
        [*] --> DarkTheme : Default
        DarkTheme --> LightTheme : toggleTheme()
        LightTheme --> DarkTheme : toggleTheme()

        note right of DarkTheme
            --bg-body: #09090b
            --accent: #f59e0b (amber)
        end note
        note right of LightTheme
            --bg-body: #ffffff
            --accent: #10069f (deep blue)
        end note
    }
